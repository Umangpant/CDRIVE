# Spring Boot local runtime
DB_HOST=localhost
DB_PORT=3307
DB_NAME=ecomm
DB_USERNAME=ecomm
DB_PASSWORD=ecomm123
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5673
RABBITMQ_USERNAME=ecomm
RABBITMQ_PASSWORD=ecomm123
JWT_SECRET=change-me-before-production-1234567890
APP_FRONTEND_BASE_URL=http://localhost:5173
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
APP_PASSWORD_RESET_EXPIRATION_MINUTES=30
APP_PASSWORD_BCRYPT_STRENGTH=12
APP_MAIL_ENABLED=false
APP_MAIL_FROM=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USERNAME=
BREVO_SMTP_PASSWORD=
# Brevo expects:
# - BREVO_SMTP_USERNAME = your Brevo SMTP login email
# - BREVO_SMTP_PASSWORD = a generated Brevo SMTP key
# - APP_MAIL_FROM = a verified sender email in Brevo, not the SMTP login itself
# - APP_CORS_ALLOWED_ORIGINS can be a comma-separated list for deployed frontends

# Docker Compose published host ports
APP_HOST_PORT=8080
MYSQL_HOST_PORT=3307
RABBITMQ_AMQP_PORT=5673
RABBITMQ_MANAGEMENT_PORT=15672

# MySQL
MYSQL_DATABASE=ecomm
MYSQL_USER=ecomm
MYSQL_PASSWORD=ecomm123
MYSQL_ROOT_PASSWORD=rootpass

# RabbitMQ
RABBITMQ_DEFAULT_USER=ecomm
RABBITMQ_DEFAULT_PASS=ecomm123
